{
    "manifest_version": 2,
    "name": "Steam Buttons",
    "version": "1.0",
    "description": "Add SteamHistory and Shadefall buttons to user profiles.",
    "permissions": [
		"https://shadefall.net/*",
		"https://steamhistory.net/*",
		"https://raw.githubusercontent.com/*"
	],
    "background": {
		"scripts": ["background.js"],
		"persistent": false
    },
    "icons": {
		"16": "icons/icon-16.png",
		"48": "icons/icon-48.png",
		"128": "icons/icon-128.png",
		"512": "icons/icon-512.png"
    },
    "content_scripts": [
	{
		"matches": ["*://*.steamcommunity.com/*"],
		"js": ["content.js"]
	}
    ],
    "browser_specific_settings": {
		"gecko": {
		"id": "SteamButtons@Teltta"
		}
	}
}
  